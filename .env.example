# LLM Provider: "gemini" (free) or "anthropic" (paid)
LLM_PROVIDER=gemini

# Google Gemini (FREE) — https://aistudio.google.com/apikey adresinden alinabilir
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic (PAID, optional) — only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily Search API — https://tavily.com adresinden ucretsiz alinabilir
TAVILY_API_KEY=your_tavily_api_key_here
